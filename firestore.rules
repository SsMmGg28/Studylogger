rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only owner can read/write their own doc
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Goals subcollection: only owner can CRUD
      match /goals/{goalId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // FCM tokens subcollection: only owner can write
      match /tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Topic progress subcollection: only owner can CRUD
      match /topicProgress/{subjectId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Weekly schedule subcollection: only owner can CRUD
      match /schedule/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Username reservations: anyone authenticated can read; only owner can write
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // username is permanent
    }

    // Study logs: owner can CRUD.
    match /studyLogs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Exam logs: owner can CRUD
    match /examLogs/{logId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Friendships: participants can read/write
    match /friendships/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
      allow create: if request.auth != null &&
        (request.resource.data.userA == request.auth.uid || request.resource.data.userB == request.auth.uid);
      allow update: if request.auth != null &&
        (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
      allow delete: if request.auth != null &&
        (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
    }

    // Cloud timer sessions: one document per user, only owner can read/write
    match /timerSessions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
